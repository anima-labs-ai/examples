# Anima API key (master key — needed for domain/agent/webhook operations)
ANIMA_API_KEY=mk_your_anima_api_key

# Organization ID (find via API or console)
ANIMA_ORG_ID=org_your_org_id

# Domain to connect for email (default: brawz.ai)
ANIMA_DOMAIN=brawz.ai

# Email address to send test email TO (your personal email to verify delivery)
TEST_EMAIL_TO=you@example.com

# Phone number to send test SMS TO (E.164 format)
TEST_SMS_TO=+15551234567

# Webhook URL for receiving events (optional — use https://webhook.site for testing)
# Leave empty to skip webhook tests
WEBHOOK_URL=
