# Anima API key — get one at https://useanima.sh/dashboard
ANIMA_API_KEY=sk_live_...

# OpenAI key for the browser-use LLM driver
OPENAI_API_KEY=sk-...

# The Hacker News account the agent will log into.
# These are seeded once into the Anima vault by this script, then the
# script never references them again — the extension fills them into
# the form from the vault.
HN_USERNAME=your-hn-username
HN_PASSWORD=your-hn-password

# Absolute path to the built Anima extension directory.
# Default assumes you're running from the repo root with the extension built.
ANIMA_EXTENSION_PATH=../../anima/apps/extension/dist
